@using rent_for_students.ViewModels
@using rent_for_students.Domain.Flyweight
@inject RoomTypeFlyweightFactory RoomTypeFactory
@model ListingCreateViewModel
@{
    ViewData["Title"] = "Створити оголошення";
}

<h2>Створити оголошення</h2>

<form method="post" class="card">
    <div asp-validation-summary="All" style="color:#b00020;"></div>

    <label>Назва</label>
    <input asp-for="Title" />
    <span asp-validation-for="Title" style="color:#b00020;"></span>

    <label>Опис</label>
    <textarea asp-for="Description" rows="4"></textarea>
    <span asp-validation-for="Description" style="color:#b00020;"></span>

    <label>Місто</label>
    <input asp-for="City" />
    <span asp-validation-for="City" style="color:#b00020;"></span>

    <label>Район</label>
    <input asp-for="District" />
    <span asp-validation-for="District" style="color:#b00020;"></span>

    <label>Ціна / міс</label>
    <input asp-for="PricePerMonth" type="number" step="0.01" />
    <span asp-validation-for="PricePerMonth" style="color:#b00020;"></span>

    <label>Тип кімнати</label>
    <select asp-for="RoomType">
        @foreach (var pair in RoomTypeFactory.GetAll())
        {
            <option value="@pair.Key">@pair.Value.DisplayName</option>
        }
    </select>
    <span asp-validation-for="RoomType" style="color:#b00020;"></span>

    <label>Площа (м²)</label>
    <input asp-for="AreaSqm" type="number" />
    <span asp-validation-for="AreaSqm" style="color:#b00020;"></span>

    <div style="margin-top:12px;">
        <button class="btn btn-primary" type="submit">Зберегти</button>
        <a class="btn" asp-action="Index">Відміна</a>
    </div>
</form>
